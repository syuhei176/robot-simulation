{
  "name": "microbots-rl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MuJoCo 3D snake robot simulator: dashboard to compare a base climbing gait vs a course-general residual-RL policy across terrains, plus servo/BOM sizing",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "quality-check": "pnpm lint && pnpm format:check && pnpm type-check",
    "train-snake": "node scripts/train-snake.ts",
    "verify-policy": "node scripts/verify-policy.ts"
  },
  "dependencies": {
    "@mujoco/mujoco": "^3.9.0",
    "@tensorflow/tfjs": "^4.22.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^26.0.0",
    "@types/three": "^0.184.1",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
